<% content_for :page_title, t(".title") %>
<% content_for :back_link_url, back_history_path(origin: true, default: teacher_interface_application_form_path) %>


<%= form_with url: [:teacher_interface, :application_form, @decision_review_request, :confirm], method: :post do |f| %>
  <span class="govuk-caption-l">Your decision review request</span>
  <h1 class="govuk-heading-l"><%= t(".title") %></h1>

  <%= render(CheckYourAnswersSummary::Component.new(
    id: "decision-review-request",
    model: @decision_review_request,
    title: "Decision review request",
    fields: {
      comment: {
        title: "Your decision review reason",
        value: simple_format(@decision_review_request.comment),
        href: edit_teacher_interface_application_form_decision_review_request_path(@decision_review_request)
      },
      has_supporting_documents: {
        title: "Add supporting evidence",
        href: edit_teacher_interface_application_form_decision_review_request_path(@decision_review_request)
      },
      decision_review_evidence_document: @decision_review_request.has_supporting_documents? ? {
        title: "Supporting evidence documents",
        href: [:teacher_interface, :application_form, @decision_review_request.decision_review_evidence_document]
      } : nil,
    },
    changeable: true
  )) %>

  <h2 class="govuk-heading-m">Submitting your request</h2>
  <p class="govuk-body">By selecting ‘Submit request’ you confirm that, to the best of your knowledge, the details you’ve provided are correct.</p>
  <p class="govuk-body">You will not be able to change your request, add new documents or delete anything once you submit it.</p>

  <%= f.govuk_submit "Submit request" do %>
    <%= govuk_link_to "Cancel", teacher_interface_application_form_path %>
  <% end %>
<% end %>
