<% content_for :page_title, title_with_error_prefix(t(".title"), error: @form.errors.any?) %>
<% content_for :back_link_url, assessor_interface_application_form_path(@application_form) %>

<%= form_with model: @form, url: [:assessor_interface, @application_form, @assessment, @decision_review_request], method: :put do |f| %>
  <%= f.govuk_error_summary %>

  <h1 class="govuk-heading-xl">
    <%= t(".title") %>
  </h1>

  <%= govuk_summary_card(title: "Decision review request") do |card| %>
    <p class="govuk-hint govuk-!-margin-bottom-2"><%= @decision_review_request.received_at.to_date.to_fs %></p>
    <h3 class="govuk-heading-s govuk-!-margin-bottom-2">Applicant’s comments</h3>

    <p class="govuk-body govuk-!-margin-bottom-2">
      <%= simple_format @decision_review_request.comment %>
    </p>

    <h3 class="govuk-heading-s govuk-!-margin-bottom-2">Applicant’s supporting evidence</h3>
    <% if @decision_review_request.has_supporting_documents? %>
      <%= document_link_to(@decision_review_request.decision_review_evidence_document) %>
      <%= document_link_to(@decision_review_request.decision_review_evidence_document, translated: true) %>
    <% else %>
      <p class="govuk-body govuk-!-margin-bottom-2">None provided</p>
    <% end %>
  <% end %>

  <%= f.govuk_radio_buttons_fieldset :review_passed do %>
    <%= f.govuk_radio_button :review_passed, true, label: { text: "Yes" }, link_errors: true, disabled: @decision_review_request.reviewed_at.present? || !policy([:assessor_interface,@decision_review_request ]).update? do %>
      <%= f.govuk_text_area :review_passed_note, label: { text: "Add an internal note" }, disabled: @decision_review_request.reviewed_at.present? || !policy([:assessor_interface,@decision_review_request ]).update? %>
    <% end %>
    <%= f.govuk_radio_button :review_passed, false, label: { text: "No" }, disabled: @decision_review_request.reviewed_at.present? || !policy([:assessor_interface,@decision_review_request ]).update? do %>
      <%= f.govuk_text_area :review_failed_note, label: { text: "Note to the applicant" }, disabled: @decision_review_request.reviewed_at.present? || !policy([:assessor_interface,@decision_review_request ]).update? %>
    <% end %>
  <% end %>

  <%= f.govuk_submit disabled: @decision_review_request.reviewed_at.present? || !policy([:assessor_interface,@decision_review_request ]).update? do %>
    <%= render "shared/assessor_interface/cancel_link" %>
  <% end %>
<% end %>
