<% content_for :page_title, "Confirm decision review" %>
<% content_for :back_link_url, assessor_interface_application_form_path(@application_form) %>

<% if @decision_review_request.review_passed? %>
  <h1 class="govuk-heading-xl">
    You have successfully reversed the decline decision
  </h1>

  <p class="govuk-body">The applicant will receive an email to notify them of this decision.</p>
<% else %>
  <h1 class="govuk-heading-xl">
    You have successfully rejected the request to reverse this decision
  </h1>

  <p class="govuk-body">The applicant will receive an email to notify them of this decision alongside your note.</p>
<% end %>

<div class="govuk-button-group">
  <%= govuk_button_link_to "Back to application list", %i[assessor_interface application_forms] %>
  <%= govuk_button_link_to "See application overview", [:assessor_interface, @application_form], secondary: true %>
</div>
