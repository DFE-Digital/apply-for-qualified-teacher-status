<%
  title = if @decision_review_request.review_passed?
    "You have moved this application into assessment"
  else
    "Decision review for QTS application #{@application_form.reference} has been rejected"
  end
%>
<% content_for :page_title, title %>
<% content_for :back_link_url, assessor_interface_application_form_path(@application_form) %>

<h1 class="govuk-heading-xl"><%= title %></h1>

<% if @decision_review_request.review_passed? %>
  <p class="govuk-body">You have changed the decline decision and moved the application back into assessment.</p>

  <p class="govuk-body">The applicant will receive an email notifying them that their decision review request has been accepted.</p>
<% else %>
  <p class="govuk-body">This means this application will remain declined. The applicant will receive an email to notify them of this decision alongside your note.</p>
<% end %>

<div class="govuk-button-group">
  <%= govuk_button_link_to "Back to application list", %i[assessor_interface application_forms] %>
  <%= govuk_button_link_to "See application overview", [:assessor_interface, @application_form], secondary: true %>
</div>
